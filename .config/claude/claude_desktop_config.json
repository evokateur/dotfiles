{
  "mcpServers": {
    "rag-knowledge": {
      "command": "/Users/wesley/.local/bin/uv",
      "args": [
        "run",
        "--directory",
        "/Users/wesley/code/rag-knowledge-mcp",
        "python",
        "rag_knowledge_mcp.py"
      ],
      "env": {
        "LOG_LEVEL": "INFO"
      }
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "@mauricio.wolff/mcp-obsidian@latest",
        "/Users/wesley/vaults/caveau"
      ]
    }
  },
  "preferences": {
    "menuBarEnabled": true,
    "chromeExtensionEnabled": false,
    "quickEntryShortcut": {
      "accelerator": "Alt+Space"
    },
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "chat",
    "coworkWebSearchEnabled": true
  }
}
